---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  return `${d.getFullYear()} 年 ${d.getMonth()+1} 月 ${d.getDate()} 日`;
}

const categoryColors: Record<string, string> = {
  '數據報告': 'tag-blue',
  '產品知識': 'tag-green',
  '經營觀點': 'tag-amber',
  '留才策略': 'tag-rose',
  '職場健康': 'tag-green',
  '員工福利': 'tag-amber',
};
---

<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{post.data.title} | Here Hear AI-EAP</title>
<meta name="description" content={post.data.excerpt}>
<link rel="canonical" href={Astro.url.href}>

<!-- Open Graph（Facebook、LINE 分享預覽） -->
<meta property="og:type" content="article">
<meta property="og:title" content={`${post.data.title} | Here Hear AI-EAP`}>
<meta property="og:description" content={post.data.excerpt}>
<meta property="og:url" content={Astro.url.href}>
<meta property="og:site_name" content="Here Hear AI-EAP">
<meta property="og:locale" content="zh_TW">
<meta property="article:published_time" content={post.data.date}>
<meta property="article:section" content={post.data.category}>

<!-- Twitter Card -->
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content={post.data.title}>
<meta name="twitter:description" content={post.data.excerpt}>

<!-- JSON-LD 結構化資料（Google 最愛讀這個） -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.excerpt,
  "datePublished": post.data.date,
  "author": {
    "@type": "Organization",
    "name": "Here Hear AI-EAP",
    "url": "https://here-hear.ai"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Here Hear AI-EAP",
    "url": "https://here-hear.ai"
  },
  "url": Astro.url.href,
  "articleSection": post.data.category,
  "inLanguage": "zh-TW"
})} />

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700;900&family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;font-size:16px;}
body{font-family:'Noto Sans TC','Inter',system-ui,sans-serif;color:#111827;background:#fff;line-height:1.7;overflow-x:hidden;}
a{text-decoration:none;color:inherit;transition:all .25s;}
button{cursor:pointer;border:none;font-family:inherit;}

:root{
  --blue:#2563EB;--blue-dark:#1D4ED8;--blue-bg:#EFF6FF;
  --green:#059669;--green-bg:#ECFDF5;
  --amber:#D97706;--amber-bg:#FFFBEB;
  --rose:#E11D48;--rose-bg:#FFF1F2;
  --text:#111827;--text-2:#374151;--text-3:#6B7280;--text-4:#9CA3AF;
  --bg:#FFFFFF;--bg-2:#F9FAFB;--bg-3:#F3F4F6;--bg-dark:#0F172A;
  --border:#E5E7EB;
  --shadow-sm:0 1px 2px rgba(0,0,0,.05);
  --shadow-xl:0 20px 25px rgba(0,0,0,.07),0 10px 10px rgba(0,0,0,.04);
  --r:8px;--r-lg:16px;--r-xl:24px;--r-full:9999px;
  --max-w:1160px;
  --transition:all .2s ease;
}

.container{max-width:var(--max-w);margin:0 auto;padding:0 24px;}

/* NAV */
.nav{position:sticky;top:0;z-index:100;background:rgba(255,255,255,.95);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);}
.nav-inner{display:flex;align-items:center;justify-content:space-between;height:64px;max-width:var(--max-w);margin:0 auto;padding:0 24px;}
.nav-logo{display:flex;align-items:center;}
.logo-text{font-size:1.25rem;font-weight:800;letter-spacing:-.02em;line-height:1;}
.brand-green{color:#4CAF50;}
.brand-purple{color:#7B3FE4;}
.nav-links{display:flex;gap:4px;align-items:center;}
.nav-links a{padding:6px 12px;border-radius:var(--r);font-size:.88rem;font-weight:500;color:var(--text-2);transition:var(--transition);}
.nav-links a:hover,.nav-links a.active{color:var(--blue);background:var(--blue-bg);}
.nav-right{display:flex;align-items:center;gap:12px;}
.btn{display:inline-flex;align-items:center;gap:6px;padding:11px 24px;border-radius:var(--r);font-size:.9rem;font-weight:600;transition:var(--transition);border:1.5px solid transparent;}
.btn-primary{background:var(--blue);color:#fff;border-color:var(--blue);}
.btn-primary:hover{background:var(--blue-dark);}
.btn-sm{padding:7px 16px;font-size:.82rem;}
.login-link{font-size:.88rem;font-weight:500;color:var(--text-2);}
@media(max-width:900px){.nav-links,.nav-right{display:none;}}

/* ARTICLE LAYOUT */
.article-wrap{max-width:760px;margin:0 auto;padding:48px 24px 80px;}

/* BREADCRUMB */
.breadcrumb{display:flex;align-items:center;gap:6px;font-size:.78rem;color:var(--text-4);margin-bottom:24px;}
.breadcrumb a:hover{color:var(--blue);}

/* HEADER */
.article-header{margin-bottom:40px;padding-bottom:32px;border-bottom:1px solid var(--border);}
.tag{display:inline-flex;align-items:center;padding:3px 10px;border-radius:var(--r-full);font-size:.72rem;font-weight:600;}
.tag-blue{background:var(--blue-bg);color:var(--blue);}
.tag-green{background:var(--green-bg);color:var(--green);}
.tag-amber{background:var(--amber-bg);color:var(--amber);}
.tag-rose{background:var(--rose-bg);color:var(--rose);}
.article-title{font-size:clamp(1.6rem,3.5vw,2.2rem);font-weight:900;line-height:1.25;letter-spacing:-.025em;margin:16px 0 12px;color:var(--text);}
.article-excerpt{font-size:1.05rem;color:var(--text-3);line-height:1.75;margin-bottom:16px;}
.article-meta{display:flex;align-items:center;gap:16px;font-size:.8rem;color:var(--text-4);font-weight:500;}
.meta-divider{width:3px;height:3px;border-radius:50%;background:var(--border);}

/* CONTENT */
.article-content{color:var(--text-2);font-size:1rem;line-height:1.85;}
.article-content h1{font-size:1.6rem;font-weight:900;line-height:1.25;letter-spacing:-.02em;margin:2.5rem 0 1rem;color:var(--text);}
.article-content h2{font-size:1.35rem;font-weight:800;line-height:1.3;letter-spacing:-.015em;margin:2.2rem 0 .9rem;color:var(--text);padding-bottom:.5rem;border-bottom:2px solid var(--border);}
.article-content h3{font-size:1.1rem;font-weight:700;line-height:1.4;margin:1.8rem 0 .7rem;color:var(--text);}
.article-content h4{font-size:1rem;font-weight:700;margin:1.4rem 0 .5rem;color:var(--text);}
.article-content p{margin-bottom:1.2rem;}
.article-content strong{font-weight:700;color:var(--text);}
.article-content em{font-style:italic;}
.article-content ul,.article-content ol{margin:0 0 1.2rem 1.5rem;display:flex;flex-direction:column;gap:.4rem;}
.article-content li{line-height:1.75;}
.article-content blockquote{border-left:4px solid var(--blue);background:var(--blue-bg);padding:16px 20px;margin:1.5rem 0;border-radius:0 var(--r) var(--r) 0;font-style:italic;color:var(--text-2);}
.article-content hr{border:none;border-top:1px solid var(--border);margin:2rem 0;}
.article-content a{color:var(--blue);text-decoration:underline;text-underline-offset:2px;}
.article-content a:hover{color:var(--blue-dark);}

/* TABLE */
.article-content table{width:100%;border-collapse:collapse;margin:1.5rem 0;font-size:.88rem;overflow-x:auto;display:block;}
.article-content thead{background:var(--bg-3);}
.article-content th{padding:10px 14px;font-weight:700;text-align:left;border:1px solid var(--border);color:var(--text);}
.article-content td{padding:10px 14px;border:1px solid var(--border);color:var(--text-2);line-height:1.6;}
.article-content tr:nth-child(even){background:var(--bg-2);}

/* CTA */
.article-cta{background:linear-gradient(135deg,var(--blue-bg),#ede9fe);border-radius:var(--r-xl);padding:40px;text-align:center;margin-top:56px;}
.article-cta h3{font-size:1.25rem;font-weight:800;color:var(--text);margin-bottom:10px;}
.article-cta p{font-size:.95rem;color:var(--text-3);margin-bottom:24px;}
.btn-cta{background:var(--blue);color:#fff;padding:12px 28px;border-radius:var(--r);font-size:.95rem;font-weight:700;display:inline-flex;border:none;cursor:pointer;transition:var(--transition);}
.btn-cta:hover{background:var(--blue-dark);transform:translateY(-1px);}

/* BACK LINK */
.back-link{display:inline-flex;align-items:center;gap:6px;font-size:.85rem;font-weight:600;color:var(--text-3);margin-top:48px;transition:var(--transition);}
.back-link:hover{color:var(--blue);}

/* FOOTER */
.footer{background:var(--bg-dark);color:rgba(255,255,255,.6);padding:48px 0 32px;}
.footer-inner{display:flex;justify-content:space-between;align-items:flex-start;gap:32px;flex-wrap:wrap;}
.footer .brand-green{color:#81C784;}
.footer .brand-purple{color:#C4B5FD;}
.footer-copy{text-align:center;margin-top:32px;padding-top:24px;border-top:1px solid rgba(255,255,255,.08);font-size:.78rem;}
</style>
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <span class="logo-text"><span class="brand-green">Here</span><span class="brand-purple">Hear</span><span class="brand-green">.AI</span></span>
    </a>
    <div class="nav-links">
      <a href="/">首頁</a>
      <a href="/">AI-EAP 服務</a>
      <a href="/">智慧心理支持站</a>
      <a href="/">方案與定價</a>
      <a href="/blog" class="active">產業觀點</a>
      <a href="/">FAQ</a>
    </div>
    <div class="nav-right">
      <a href="/" class="login-link">HR 登入</a>
      <a href="/" class="btn btn-primary btn-sm">免費試用</a>
    </div>
  </div>
</nav>

<!-- ARTICLE -->
<main>
  <div class="article-wrap">

    <!-- BREADCRUMB -->
    <nav class="breadcrumb">
      <a href="/">首頁</a>
      <span>›</span>
      <a href="/blog">產業觀點</a>
      <span>›</span>
      <span>{post.data.category}</span>
    </nav>

    <!-- HEADER -->
    <header class="article-header">
      <span class={`tag ${categoryColors[post.data.category] ?? 'tag-blue'}`}>{post.data.category}</span>
      <h1 class="article-title">{post.data.title}</h1>
      <p class="article-excerpt">{post.data.excerpt}</p>
      <div class="article-meta">
        <span>{formatDate(post.data.date)}</span>
        <span class="meta-divider"></span>
        <span>閱讀時間 {post.data.readTime} 分鐘</span>
      </div>
    </header>

    <!-- CONTENT -->
    <article class="article-content">
      <Content />
    </article>

    <!-- CTA -->
    <div class="article-cta">
      <h3>想了解 Here Hear AI-EAP 如何幫助您的企業？</h3>
      <p>免費體驗 AI 心理健康對話，看看員工的使用率能提升多少</p>
      <a href="/" class="btn-cta">預約免費 Demo →</a>
    </div>

    <!-- NEWSLETTER -->
    <div style="background:var(--bg-2);border-radius:var(--r-xl);padding:32px;text-align:center;margin-top:32px;">
      <h3 style="font-size:1rem;font-weight:700;color:var(--text);margin-bottom:6px;">📩 訂閱電子報，每兩週收到職場心理健康洞察</h3>
      <div style="display:flex;gap:8px;justify-content:center;margin-top:14px;flex-wrap:wrap;" id="nlForm">
        <input type="email" id="nlEmail" placeholder="請輸入 Email" style="padding:10px 16px;border-radius:var(--r);border:1.5px solid var(--border);font-family:inherit;font-size:.88rem;width:260px;max-width:100%;outline:none;">
        <button onclick="handleSubscribe()" id="nlBtn" style="background:var(--blue);color:#fff;padding:10px 20px;border-radius:var(--r);font-size:.88rem;font-weight:600;border:none;cursor:pointer;">訂閱</button>
      </div>
      <p id="nlMsg" style="margin-top:10px;font-size:.85rem;display:none;"></p>
    </div>

    <!-- BACK -->
    <a href="/blog" class="back-link">
      ← 返回所有文章
    </a>

  </div>
</main>

<script is:inline>
  async function handleSubscribe() {
    const email = document.getElementById('nlEmail').value.trim();
    const btn = document.getElementById('nlBtn');
    const msg = document.getElementById('nlMsg');
    if (!email || !email.includes('@')) {
      msg.textContent = '請輸入有效的 Email 地址';
      msg.style.color = '#E11D48';
      msg.style.display = 'block';
      return;
    }
    btn.disabled = true;
    btn.textContent = '處理中...';
    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      const data = await res.json();
      if (data.success) {
        document.getElementById('nlForm').style.display = 'none';
        msg.textContent = data.message;
        msg.style.color = '#059669';
        msg.style.fontWeight = '600';
        msg.style.display = 'block';
      } else {
        msg.textContent = data.error || '訂閱失敗，請稍後再試';
        msg.style.color = '#E11D48';
        msg.style.display = 'block';
        btn.disabled = false;
        btn.textContent = '訂閱';
      }
    } catch (e) {
      msg.textContent = '網路錯誤，請稍後再試';
      msg.style.color = '#E11D48';
      msg.style.display = 'block';
      btn.disabled = false;
      btn.textContent = '訂閱';
    }
  }
  document.getElementById('nlEmail').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') handleSubscribe();
  });
</script>

<!-- FOOTER -->
<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <div>
        <span class="logo-text"><span class="brand-green">Here</span><span class="brand-purple">Hear</span><span class="brand-green">.AI</span></span>
        <p style="margin-top:8px;font-size:.82rem;">企業 AI 心理健康服務平台</p>
      </div>
      <div style="display:flex;gap:48px;flex-wrap:wrap;">
        <div>
          <p style="font-weight:600;color:rgba(255,255,255,.9);margin-bottom:10px;font-size:.85rem;">產品</p>
          <div style="display:flex;flex-direction:column;gap:6px;font-size:.82rem;">
            <a href="/" style="color:rgba(255,255,255,.5);">AI-EAP 服務</a>
            <a href="/" style="color:rgba(255,255,255,.5);">方案與定價</a>
          </div>
        </div>
        <div>
          <p style="font-weight:600;color:rgba(255,255,255,.9);margin-bottom:10px;font-size:.85rem;">資源</p>
          <div style="display:flex;flex-direction:column;gap:6px;font-size:.82rem;">
            <a href="/blog" style="color:rgba(255,255,255,.5);">產業觀點</a>
            <a href="/" style="color:rgba(255,255,255,.5);">FAQ</a>
          </div>
        </div>
      </div>
    </div>
    <div class="footer-copy">© 2026 Here Hear AI-EAP. All rights reserved.</div>
  </div>
</footer>

</body>
</html>
